protab:Toggle("Remove Hit Cooldown", function(v)
    notify("Remove Hit Cooldown", v and "Enabled." or "Disabled.", 2)
    if v and hum then
        hum:GetAttributeChangedSignal("HitCooldown"):Connect(function()
            if v then
                hum:SetAttribute("HitCooldown", false)
            end
        end)
    end
end)

protab:Toggle("Remove Fall Damage", function(v)
    notify("Remove Fall Damage", v and "Enabled." or "Disabled.", 2)
    local fallDamage = char:FindFirstChild("FallDamage")
    if fallDamage then fallDamage.Enabled = not v end
end)

protab:Button("Infinite Stamina", function()
    if hum then
        hum:SetAttribute("MaxStamina", math.huge)
        hum:SetAttribute("Stamina", math.huge)
    end
end)

protab:Button("Reveal Landmines", function()
    local mineField = workspace:FindFirstChild("Minefield")
    if mineField then
        for _, part in pairs(mineField:GetChildren()) do
            if part.Name == "Landmine" then
                part.Transparency = 0.3
                part.Color = Color3.fromRGB(255, 0, 0)
            end
        end
    end
end)

workspace.ChildAdded:Connect(function(obj)
