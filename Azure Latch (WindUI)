    TrapHelperSection:Slider({
        Flag = "TrapHelperMaxDistance",
        Title = "Trap Helper Max Distance",
        Step = 1,
        Value = {
            Min = 50,
            Max = 200,
            Default = Settings.trapHelperMaxDistance,
        },
