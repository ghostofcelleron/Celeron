    local function tableToJSON(tbl)
        local function serialize(obj)
            local lua = type(obj) == "number" and tostring(obj) or
                       type(obj) == "string" and string.format("%q", obj) or
                       type(obj) == "boolean" and tostring(obj) or
                       type(obj) == "table" and (function()
                           local res = "{"
                           for k, v in pairs(obj) do
                               res = res .. "[" .. serialize(k) .. "]=" .. serialize(v) .. ","
                           end
                           return res .. "}"
                       end)() or
                       "nil"
            return lua
        end
        return serialize(tbl)
    end

