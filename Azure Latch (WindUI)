        Flag = "TrapHelper",
        Title = "Trap Helper",
        Value = Settings.trapHelperEnabled,
        Callback = function(v)
            Settings.trapHelperEnabled = v
            trapState.enabled = v
            WindUI:Notify({
                Title = "Trap Helper",
                Content = v and "Enabled." or "Disabled.",
                Duration = 1
            })
        end,
    })

