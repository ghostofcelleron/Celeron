killer:Toggle("Teleport Kill", "Constantly Teleports Behind The Selected Player.", function(state)
    tpKill = state
    if tpKill then
        notify2("Teleport Kill", "Enabled.")
        tpConn = game:GetService("RunService").Heartbeat:Connect(function()
            local char = game.Players.LocalPlayer.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            local targetChar
            local playersFolder = workspace:FindFirstChild("PLAYERS")
            local aliveFolder = playersFolder and playersFolder:FindFirstChild("ALIVE")
            if not aliveFolder then return end
            if mode == "Closest" then
                local closest
                local dist = math.huge
                for _,v in ipairs(aliveFolder:GetChildren()) do
                    local hrp = v:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local d = (root.Position - hrp.Position).Magnitude
                        if d < dist then
                            dist = d
                            closest = v
                        end
                    end
                end
                targetChar = closest
            elseif mode == "Specific" then
                targetChar = aliveFolder:FindFirstChild(targetName)
            end
            if targetChar then
                local hrp = targetChar:FindFirstChild("HumanoidRootPart")
                if hrp then
                    root.CFrame = hrp.CFrame * CFrame.new(0,0,3)
                end
            end
        end)
    else
        if tpConn then tpConn:Disconnect() end
        notify2("Teleport Kill", "Disabled.")
    end
end)

