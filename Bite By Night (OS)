        return
    end

    local formatted = text:gsub("%s+", "")

    local success, key = pcall(function()
        return Enum.KeyCode[formatted]
    end)

    if success and key then
        aimlockBind = key
        notify2("Aimlock Bind", "Bind Set To: " .. key.Name)
        return
    end

    local success2, inputType = pcall(function()
        return Enum.UserInputType[formatted]
    end)

    if success2 and inputType then
        aimlockBind = inputType
        notify2("Aimlock Bind", "Bind Set To: " .. inputType.Name)
    else
        aimlockBind = Enum.UserInputType.MouseButton2
        notify2("Aimlock Bind", "Invalid Input. Bind Is Now M2.")
    end
end)

