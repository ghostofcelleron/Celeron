local espTable = {}

vistab:Toggle("Survivor ESP", "Highlight All Survivors.", function(state)
    if state then
        espTable.Survivors = true

        local function highlightSurvivor(char)
            if espTable[char] then return end

            local highlight = Instance.new("Highlight")
            highlight.Name = "SurvivorHighlight"
            highlight.FillColor = Color3.fromRGB(80, 180, 255)
            highlight.OutlineColor = Color3.fromRGB(120, 200, 255)
            highlight.FillTransparency = 0.7
            highlight.OutlineTransparency = 0.3
            highlight.Adornee = char
            highlight.Parent = char

            espTable[char] = highlight
        end

        local function refreshSurvivors()
            local aliveFolder = workspace.PLAYERS.ALIVE
            if aliveFolder then
                for _, char in ipairs(aliveFolder:GetChildren()) do
                    if char:IsA("Model") then
                        highlightSurvivor(char)
                    end
                end
            end
        end

        refreshSurvivors()

        espTable.SurvivorConnection = workspace.PLAYERS.ALIVE.ChildAdded:Connect(function(char)
            if espTable.Survivors and char:IsA("Model") then
                highlightSurvivor(char)
            end
        end)

        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Survivor ESP",
            Text = "Enabled.",
            Duration = 2
        })

    else
        espTable.Survivors = false

        if espTable.SurvivorConnection then
            espTable.SurvivorConnection:Disconnect()
            espTable.SurvivorConnection = nil
        end

        for model, highlight in pairs(espTable) do
            if typeof(model) == "Instance" and highlight and highlight.Parent and model:IsDescendantOf(workspace.PLAYERS.ALIVE) then
                highlight:Destroy()
                espTable[model] = nil
            end
        end

        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Survivor ESP",
            Text = "Disabled.",
            Duration = 2
        })
    end
end)

