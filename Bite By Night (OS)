getgenv().AutoParryEnabled = false

survivor:Toggle("Auto Parry", "Automatically Attempts To Parry Killer Attacks.", function(v)
    getgenv().AutoParryEnabled = v

    local attack = {
        "rbxassetid://106673226682917",
        "rbxassetid://112503015929213",
        "rbxassetid://120428956410756",
        "rbxassetid://133752270724243",
    }

    local connection

    local function isAttackAnimation(track)
        if not track or not track.Animation then return false end
        local id = track.Animation.AnimationId
        for _, aid in ipairs(attack) do
            if id == aid then return true end
        end
        return false
    end

    local function getParryRange(track)
        if not track or not track.Animation then 
            return getgenv().BasicAttackRange or 30 
        end
        if track.Animation.AnimationId == "rbxassetid://133752270724243" then
            return getgenv().PullAttackRange or 50
        end
        return getgenv().BasicAttackRange or 30
    end

    if getgenv().AutoParryEnabled then
        notify2("Auto Parry", "Enabled.")

        connection = game:GetService("RunService").Heartbeat:Connect(function()
            if not getgenv().AutoParryEnabled then return end

            local lp = game.Players.LocalPlayer
            local char = lp.Character
            if not char then return end

            local myRoot = char:FindFirstChild("HumanoidRootPart")
            if not myRoot then return end

            for _, plr in ipairs(game.Players:GetPlayers()) do
                if plr == lp then continue end

                local pchar = plr.Character
                if not pchar then continue end

                local attackerRoot = pchar:FindFirstChild("HumanoidRootPart")
                if not attackerRoot then continue end

                local diff = attackerRoot.Position - myRoot.Position
                local distSq = diff:Dot(diff)

                local defaultRange = getgenv().BasicAttackRange or 30
                if distSq > defaultRange * defaultRange then continue end

                local hum = pchar:FindFirstChildOfClass("Humanoid")
                if not hum then continue end

                local animator = hum:FindFirstChildOfClass("Animator")
                if not animator then continue end

                for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                    if not track.IsPlaying then continue end
                    if not isAttackAnimation(track) then continue end

                    local actualRange = getParryRange(track)

                    if distSq > actualRange * actualRange then continue end

                    local vim = game:GetService("VirtualInputManager")
                    vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    task.wait()
                    vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)

                    break
                end
            end
        end)
    else
        notify2("Auto Parry", "Disabled.")
        if connection then
            connection:Disconnect()
            connection = nil
        end
    end
end)

