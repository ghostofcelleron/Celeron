if not game:GetService("ReplicatedStorage").Resources.dio:FindFirstChild("Stand") then
	local dummy = game:GetService("ReplicatedStorage").allTypes.rig.dummy:Clone()
	dummy.Name = "Stand"
	dummy.Parent = game:GetService("ReplicatedStorage").Resources.dio

	for _, obj in ipairs(dummy:GetChildren()) do
		if obj:IsA("Accessory") then
			obj:Destroy()
		end
	end

	local torso = dummy:FindFirstChild("Torso")
	if torso then
		torso.Color = Color3.fromRGB(126, 104, 63)
	end

	local limbs = {"Head", "Right Arm", "Left Arm", "Left Leg", "Right Leg"}
	for _, limbName in ipairs(limbs) do
		local limb = dummy:FindFirstChild(limbName)
		if limb then
			limb.Color = Color3.fromRGB(193, 190, 66)
		end
	end
end

