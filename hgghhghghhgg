maintab:Button("Manual Score", function()
    local coordinateA = Vector3.new(303, 3, -1369)
    local coordinateB = Vector3.new(179, 3, -1830)
    local function teleportToPosition(position)
        local LocalCharacter = game.Players.LocalPlayer.Character
        local LocalHumanoidRootPart = LocalCharacter and LocalCharacter:FindFirstChild("HumanoidRootPart")
        if LocalHumanoidRootPart then
            LocalHumanoidRootPart.CFrame = CFrame.new(position)
        end
    end
    local function checkTeamAndTeleport()
        local teamName = game.Players.LocalPlayer.Team and game.Players.LocalPlayer.Team.Name
        if teamName == "A" then
            teleportToPosition(coordinateB)
        elseif teamName == "B" then
            teleportToPosition(coordinateA)
        end
    end
    checkTeamAndTeleport()
end)

funtab:Button("Don Lorenzo (Nagi)", function()
    local StarterGui = game:GetService("StarterGui")
    StarterGui:SetCore("SendNotification", {
        Title = "Credits",
        Text = "brought to you by celeron!",
        Duration = 5,
        Button1 = "OK",
    })

    local Players = game:GetService("Players")
    local UserInputService = game:GetService("UserInputService")
    local VirtualInputManager = game:GetService("VirtualInputManager")
    local Debris = game:GetService("Debris")

    local plr = Players.LocalPlayer
    local currentChar, currentHum, currentRoot = nil, nil, nil

    local dribbleTrack, controlJumpTrack, controlLandTrack, passTrack = nil, nil, nil, nil
    local s1db, s2db, s3db = false, false, false

    local function setupCharacter(char)
        if not char then return end
        currentChar = char
        currentHum = char:WaitForChild("Humanoid")
        currentRoot = char:WaitForChild("HumanoidRootPart")

        local skill1Anim = Instance.new("Animation")
        skill1Anim.AnimationId = "rbxassetid://102294508090597"
        dribbleTrack = currentHum:LoadAnimation(skill1Anim)
        dribbleTrack.Priority = Enum.AnimationPriority.Action2

        local skill2Anim = Instance.new("Animation")
        skill2Anim.AnimationId = "rbxassetid://90734196141468"
        controlJumpTrack = currentHum:LoadAnimation(skill2Anim)
        controlJumpTrack.Priority = Enum.AnimationPriority.Action2

        local skill2AnimVAR = Instance.new("Animation")
        skill2AnimVAR.AnimationId = "rbxassetid://82371642989185"
        controlLandTrack = currentHum:LoadAnimation(skill2AnimVAR)
        controlLandTrack.Priority = Enum.AnimationPriority.Action3

        local skill3Anim = Instance.new("Animation")
        skill3Anim.AnimationId = "rbxassetid://85862104307480"
        passTrack = currentHum:LoadAnimation(skill3Anim)
        passTrack.Priority = Enum.AnimationPriority.Action2
    end

    if plr.Character then
        setupCharacter(plr.Character)
    end
    plr.CharacterAdded:Connect(setupCharacter)

    local function haveBall()
        if not currentChar then return false end
        local Football = currentChar:FindFirstChild("Ball")
        return Football ~= nil
    end

    local function onKeyPress(inputObject, gameProcessedEvent)
        if gameProcessedEvent then return end
        if not currentHum or not currentRoot then return end

        if inputObject.KeyCode == Enum.KeyCode.One then
            if not haveBall() or s1db then return end
            s1db = true
            dribbleTrack:Play()

            local vel = Instance.new("BodyVelocity")
            vel.MaxForce = Vector3.new(1, 0, 1) * 30000
            vel.Velocity = currentRoot.CFrame.LookVector * 40
            vel.Parent = currentRoot
            Debris:AddItem(vel, 2.4)

            repeat
                task.wait()
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                if vel.Parent then vel.Velocity = currentRoot.CFrame.LookVector * 40 end
            until not vel.Parent

            task.wait(21.6)
            s1db = false

        elseif inputObject.KeyCode == Enum.KeyCode.Two then
            if haveBall() or s2db then return end
            s2db = true
            controlJumpTrack:Play()

            local did = false
            for i = 1, 2, 0.1 do
                if game.Workspace.CurrentCamera.CameraType == Enum.CameraType.Scriptable then
                    did = true
                    break
                end
                task.wait(0.1)
            end

            if did then
                controlJumpTrack:Stop()
                controlLandTrack:Play()
                task.wait(0.85)
                controlLandTrack:Stop()
            end

            task.wait(20)
            s2db = false

        elseif inputObject.KeyCode == Enum.KeyCode.Three then
            if not haveBall() or s3db then return end
            s3db = true
            passTrack:Play()
            task.wait(25)
            s3db = false
        end
    end

    print("loaded don lorenzo script")
    UserInputService.InputBegan:Connect(onKeyPress)
end)

