local DashVFXParts = {}

for i = 1, 40 do
	local part = Instance.new("Part")
	part.Anchored = true
	part.CanCollide = false
	part.Material = Enum.Material.Neon
	part.Color = Color3.fromRGB(240, 245, 255)
	part.Size = Vector3.new(0.15, 0.15, 20)
	part.Transparency = 1
	part.Parent = workspace
	part:SetAttribute("InUse", false)
	table.insert(DashVFXParts, part)
end

local function getDashPart()
	for _, part in ipairs(DashVFXParts) do
		if not part:GetAttribute("InUse") then
			part:SetAttribute("InUse", true)
			part.Transparency = 0
			return part
		end
	end
end

local function releaseDashPart(part)
	part:SetAttribute("InUse", false)
	part.Transparency = 1
end

local function playDashVFX()
	local char = plr.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	local look = root.CFrame.LookVector

	for i = 1, math.random(10,15) do
		local line = getDashPart()
		if line then
			local offset = Vector3.new(math.random(-6,6), math.random(-3,4), math.random(-6,6))
			local startPos = root.Position + offset
			line.CFrame = CFrame.lookAt(startPos, startPos + look)
			line:SetAttribute("DashVFX", true)
			local tween = TweenService:Create(line, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {Transparency = 1})
			tween:Play()
			tween.Completed:Connect(function() releaseDashPart(line) end)
		end
	end

	for i = 1, 10 do
		local line = getDashPart()
		if line then
			local offset = Vector3.new(math.random(-5,5), math.random(-3,4), math.random(-5,5))
			local startPos = root.Position - look * math.random(4, 8) + offset
			line.CFrame = CFrame.lookAt(startPos, startPos + look)
			line:SetAttribute("DashVFX", true)
			local tween = TweenService:Create(line, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {Transparency = 1})
			tween:Play()
			tween.Completed:Connect(function() releaseDashPart(line) end)
		end
	end
end

local function Skill3(char)
	CancelMove()
	if stopped or Skill3Active or IsMoveOnCD("skill3") or Stunned() then return end
	Skill3Active = true

	spawn(function()
		while Skill3Active do
			if stopped then
				Skill3Active = false
				break
			end

			local root = char:WaitForChild("HumanoidRootPart")
			DoCDVisual(0.5, "skill3")

			local dashSound = Instance.new("Sound")
			dashSound.SoundId = "rbxassetid://120170187802322"
			dashSound.Volume = 1
			dashSound.Parent = SoundService
			dashSound:Play()
			game:GetService("Debris"):AddItem(dashSound, 2)

			local distance = 75
			local direction = root.CFrame.LookVector
			local origin = root.Position

			local raycastParams = RaycastParams.new()
			raycastParams.FilterDescendantsInstances = {char}
			raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
			raycastParams.IgnoreWater = true

			local result = Workspace:Raycast(origin, direction * distance, raycastParams)
			if result then
				root.CFrame = CFrame.new(result.Position - direction * 3, result.Position + direction)
			else
				root.CFrame = root.CFrame + direction * distance
			end

			playDashVFX()
			task.wait(0.5)
		end
	end)
end

