local function Skill2(char)
	if IsMoveOnCD("skill2") then CancelMove() return end
	if HasBall() then return CancelMove() end
	if Stunned() then return end

	local root = char:WaitForChild("HumanoidRootPart")
	local humanoid = char:WaitForChild("Humanoid")
	local targetPart = workspace.Terrain:FindFirstChild("Ball")
	if not targetPart then return end	

	local heightDiff = targetPart.Position.Y - root.Position.Y
	if heightDiff < 15 then
		CancelMove()
		return
	end

	CancelMove()

	local startTime = tick()
	local timeout = 1

	local connection
	connection = RunService.RenderStepped:Connect(function()
		if not root or not targetPart then
			connection:Disconnect()
			return
		end

		if tick() - startTime >= timeout then
			connection:Disconnect()
			return
		end

		if HasBall() then
			connection:Disconnect()

			local anim = Instance.new("Animation")
			anim.AnimationId = "rbxassetid://85295479301691"
			local track = humanoid:LoadAnimation(anim)

			cam.FieldOfView = 30
			TweenService:Create(cam, TweenInfo.new(0.6), {FieldOfView = 70}):Play()

			local sound = Instance.new("Sound")
			sound.SoundId = "rbxassetid://106669508979055"
			sound.Volume = 1
			sound.Parent = SoundService
			sound:Play()

			local camera = workspace.CurrentCamera
			local originalType = camera.CameraType
			local originalSubject = camera.CameraSubject

			root.Anchored = true
			root.AssemblyLinearVelocity = Vector3.zero
			humanoid.AutoRotate = false

			camera.CameraType = Enum.CameraType.Scriptable
			camera.CFrame = CFrame.new(
				root.Position + root.CFrame.LookVector * 5 + Vector3.new(0,0.5,0),
				root.Position + Vector3.new(0,0.5,0)
			)

			local hold
			hold = RunService.RenderStepped:Connect(function()
				if not track.IsPlaying then
					hold:Disconnect()
					root.Anchored = false
					humanoid.AutoRotate = true
					camera.CameraType = originalType
					camera.CameraSubject = humanoid
					return
				end

				root.AssemblyLinearVelocity = Vector3.zero

				camera.CFrame = CFrame.new(
					root.Position + root.CFrame.LookVector * 5 + Vector3.new(0,0.5,0),
					root.Position + Vector3.new(0,0.5,0)
				)
			end)

			track:Play()
			return
		end

		if (targetPart.Position - root.Position).Magnitude > 10 then
			local pos = targetPart.Position
			local correctedPos = Vector3.new(pos.X, pos.Y - 4, pos.Z)
			local newCF = CFrame.new(correctedPos)

			root.CFrame = newCF
			RunService.RenderStepped:Wait()
			root.CFrame = newCF

			task.spawn(function()
				remote2:FireServer(buffer.fromstring(buffers["grabball"]))
			end)
		end
	end)
end

